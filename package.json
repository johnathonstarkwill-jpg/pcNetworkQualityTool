{
  "name": "pc-network-quality-tool",
  "version": "0.1.0",
  "description": "Offline Electron desktop tool for PC-to-PC network quality testing.",
  "main": "dist/main/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.json --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "fetch:iperf3": "node scripts/fetch-iperf3.mjs",
    "icon": "node scripts/render-icon.mjs"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.2"
  }
}
